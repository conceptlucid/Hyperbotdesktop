{
  "name": "@hyperbot/zalo",
  "version": "2026.3.22",
  "description": "HyperBot Zalo channel plugin",
  "type": "module",
  "dependencies": {
    "undici": "7.24.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "hyperbot": "workspace:*"
  },
  "peerDependencies": {
    "hyperbot": ">=2026.3.22"
  },
  "peerDependenciesMeta": {
    "hyperbot": {
      "optional": true
    }
  },
  "hyperbot": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "zalo",
      "label": "Zalo",
      "selectionLabel": "Zalo (Bot API)",
      "docsPath": "/channels/zalo",
      "docsLabel": "zalo",
      "blurb": "Vietnam-focused messaging platform with Bot API.",
      "aliases": [
        "zl"
      ],
      "order": 80,
      "quickstartAllowFrom": true
    },
    "install": {
      "npmSpec": "@hyperbot/zalo",
      "localPath": "extensions/zalo",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.3.22"
    },
    "release": {
      "publishToNpm": true
    }
  }
}
