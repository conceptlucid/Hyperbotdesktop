{
  "name": "ancient-claw-desktop",
  "productName": "Ancient Claw",
  "version": "1.0.0",
  "description": "AI assistant for desktop - works on any Mac",
  "main": "dist/ancient-claw.js",
  "author": "Ancient Claw Team",
  "license": "MIT",
  "scripts": {
    "build:mac": "npm run build && electron-builder --mac",
    "package:mac": "electron-builder --mac --x64"
  },
  "build": {
    "appId": "com.ancient-claw.desktop",
    "productName": "Ancient Claw",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg"],
      "minimumSystemVersion": "10.15"
    }
  }
}
